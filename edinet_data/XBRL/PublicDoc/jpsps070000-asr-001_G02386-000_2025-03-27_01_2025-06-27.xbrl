            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:160.4pt"&gt;
              &lt;p style="margin:0pt; text-align:center; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;住　　所&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:58.75pt"&gt;
              &lt;p style="margin:0pt; text-align:center; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;所有株数&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:58.8pt"&gt;
              &lt;p style="margin:0pt; text-align:center; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;所有比率&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr style="height:14.15pt"&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:160.4pt"&gt;
              &lt;p style="margin:0pt; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;ベアリング・アセット・マネジメント（アジア）ホールディングズ・リミテッド &lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:160.4pt"&gt;
              &lt;p style="margin:0pt; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;35&lt;/span&gt;&lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:6.67pt; vertical-align:super;"&gt;th&lt;/span&gt;&lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt; Floor, Gloucester Tower, 15 Queen’s Road Central, Hong Kong&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:58.75pt"&gt;
              &lt;p style="margin:0pt; text-align:right; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;5,000株&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; padding:1.5pt 0.75pt; vertical-align:middle; width:58.8pt"&gt;
              &lt;p style="margin:0pt 3pt 0pt 0pt; text-align:right; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt;"&gt;100％&lt;/span&gt;&lt;/p&gt;
