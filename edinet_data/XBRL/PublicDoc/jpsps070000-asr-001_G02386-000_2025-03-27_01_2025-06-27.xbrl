              &lt;p style="margin:0pt; text-align:right; widows:0; orphans:0;font-size:9pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9pt"&gt;△62,357,396&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
          &lt;/tr&gt;
          &lt;tr&gt;
            &lt;td style="background-color:#ffffff; border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.75pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.75pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.75pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.75pt; padding-bottom:3pt; padding-top:3pt; vertical-align:top; width:183pt"&gt;
              &lt;p style="margin:0pt; text-align:center; widows:0; orphans:0;font-size:9pt"&gt;
