            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; vertical-align:bottom; width:42pt"&gt;
              &lt;p style="margin:0pt; text-align:right; widows:0; orphans:0;font-size:10pt"&gt;
                &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt"&gt;62,500&lt;/span&gt;&lt;/p&gt;
            &lt;/td&gt;
            &lt;td style="border-bottom-color:#000000; border-bottom-style:solid; border-bottom-width:0.5pt; border-left-color:#000000; border-left-style:solid; border-left-width:0.5pt; border-right-color:#000000; border-right-style:solid; border-right-width:0.5pt; border-top-color:#000000; border-top-style:solid; border-top-width:0.5pt; vertical-align:bottom; width:54pt"&gt;
