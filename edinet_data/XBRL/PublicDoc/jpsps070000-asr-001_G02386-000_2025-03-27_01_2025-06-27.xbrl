            &lt;/table&gt;
            &lt;p style="margin: 0pt;font-size: 0pt"&gt;
              &lt;span style="font-family: &amp;apos;ＭＳ 明朝&amp;apos;;font-size: 0pt"&gt; &lt;/span&gt;&lt;/p&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    </jpsps_cor:CalculationOfNetAssetsTextBlock>
  <jpsps070000-asr_G02386-000:SupplementaryReferenceInformationAboutMotherFundCurrentStatusOfFundTextBlock contextRef="FilingDateInstant">
      &lt;p style="margin:18.3pt 0pt 5pt 0pt;font-size: 10pt"&gt;
