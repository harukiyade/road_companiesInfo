              &lt;tr&gt;
                &lt;td rowspan="12" style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9.000000pt; width:271.000000px; padding-top:4.000000px; padding-left:0.000000px; padding-right:0.000000px; padding-bottom:4.000000px; border-top:1.000000px solid #000000; border-left:1.000000px solid #000000; border-right:0.000000px none #FFFFFF; border-bottom:1.000000px solid #000000; color:#000000; text-align:center; vertical-align:top; "&gt;
