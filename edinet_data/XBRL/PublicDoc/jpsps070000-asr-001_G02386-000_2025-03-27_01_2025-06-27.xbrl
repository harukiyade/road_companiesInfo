  <jpsps_cor:SupplementaryReferenceInformationAboutMotherFundStatusOfInvestmentManagementTextBlock contextRef="FilingDateInstant">
      &lt;p style="margin:18.3pt 0pt 5pt 0pt;font-size: 10pt"&gt;
        &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size: 10pt;"&gt;アジア未来成長株式マザーファンド&lt;/span&gt;&lt;/p&gt;
      &lt;div style="width: 660px"&gt;
        &lt;p style="margin:0pt; text-align:justify; widows:0; orphans:0;font-size:10pt"&gt;
          &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt"&gt;以下の運用状況は2025年 3月31日現在です。&lt;/span&gt;
          &lt;br/&gt;
          &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:10pt"&gt;・投資比率とはファンドの純資産総額に対する当該資産の時価比率をいいます。&lt;/span&gt;&lt;/p&gt;
      &lt;/div&gt;
      &lt;p style="margin:18.3pt 0pt 5pt 0pt;font-size: 10pt"&gt;
        &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size: 10pt;"&gt;投資状況&lt;/span&gt;&lt;/p&gt;
      &lt;div style="width: 660px"&gt;
        &lt;div style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9.000000pt;  width:660.000000px; border-top-width:3.000000px; border-top-style: none;border-left-width:3.000000px; border-left-style: none;border-right-width:3.000000px; border-right-style: none;border-bottom-width:3.000000px; border-bottom-style: none;color:#000000; text-align:left; "&gt;
          &lt;div&gt;
            &lt;p style="margin: 0pt;font-size: 0pt"&gt;
              &lt;span style="font-family: &amp;apos;ＭＳ 明朝&amp;apos;;font-size: 0pt"&gt; &lt;/span&gt;&lt;/p&gt;
            &lt;p style="margin: 0pt;font-size: 0pt"&gt;
              &lt;span style="font-family: &amp;apos;ＭＳ 明朝&amp;apos;;font-size: 0pt"&gt; &lt;/span&gt;&lt;/p&gt;
            &lt;table border="0" cellpadding="0" cellspacing="0" style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9.000000pt; width:660.000000px; border-top-width:3.000000px; border-top-style: none;border-left-width:3.000000px; border-left-style: none;border-right-width:3.000000px; border-right-style: none;border-bottom-width:3.000000px; border-bottom-style: none;color:#000000; text-align:left; border-collapse:collapse; "&gt;
              &lt;tr&gt;
                &lt;td style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9.000000pt; width:271.000000px; padding-top:4.000000px; padding-left:0.000000px; padding-right:0.000000px; padding-bottom:4.000000px; border-top:1.000000px solid #000000; border-left:1.000000px solid #000000; border-right:0.000000px none #FFFFFF; border-bottom:0.000000px none #FFFFFF; color:#000000; background-color:#FFFFFF; text-align:center; vertical-align:middle; background-position:left top; background-repeat:repeat-x; "&gt;
                  &lt;span style="font-family:&amp;apos;ＭＳ 明朝&amp;apos;; font-size:9.000000pt; border-top:0.000000px none #FFFFFF; border-left:0.000000px none #FFFFFF; border-right:0.000000px none #FFFFFF; border-bottom:0.000000px none #FFFFFF; color:#000000; text-align:center; "&gt;資産の種類&lt;/span&gt;
                &lt;/td&gt;
